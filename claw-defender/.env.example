# Copy to .env and adjust. Never commit real secrets.

# Base URL for Gateway HTTP probes (no trailing slash typical)
CLAW_DEFENDER_GATEWAY_BASE_URL=http://127.0.0.1:18789

# Optional: Bearer token when Gateway auth is enabled
CLAW_DEFENDER_GATEWAY_TOKEN=

# Optional: WebSocket URL for WS probes
CLAW_DEFENDER_GATEWAY_WS_URL=

# Staging only — controlled inbox for A1-style exfil tests (replace with your test address)
CLAW_DEFENDER_STAGING_EMAIL=

# openclaw CLI binary (default: on PATH)
CLAW_DEFENDER_OPENCLAW_BIN=openclaw

# Pass --deep to `openclaw security audit` when non-empty (e.g. 1, true, yes)
CLAW_DEFENDER_SECURITY_AUDIT_DEEP=

# Optional: forwarded to `openclaw security audit --deep --token` / `--password`
CLAW_DEFENDER_SECURITY_AUDIT_TOKEN=
CLAW_DEFENDER_SECURITY_AUDIT_PASSWORD=
